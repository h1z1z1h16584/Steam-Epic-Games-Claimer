{
  "manifest_version": 3,
  "name": "Steam & Epic Games Claimer",
  "version": "1.1.0",
  "description": "Automatically checks and helps claim free promotional games on Steam and Epic Games Store.",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://store-site-backend-static-ipv4.ak.epicgames.com/*",
    "https://store.epicgames.com/*",
    "https://store.steampowered.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png"
    }
  }
}